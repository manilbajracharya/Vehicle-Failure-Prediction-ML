        {
          "name": "422 Validation Error — Invalid Make",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"make\": \"Volkswagen\",\n  \"model\": \"Golf\",\n  \"year\": 2019,\n  \"mileage_km\": 80000,\n  \"engine_type\": \"Gasoline\",\n  \"service_frequency\": 6,\n  \"recall_count\": 0,\n  \"region\": \"Ontario\",\n  \"driving_style\": \"City\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {
              "raw": "{{base_url}}/predict",
              "host": ["{{base_url}}"],
              "path": ["predict"]
            },
            "description": "Sends an unsupported make ('Volkswagen') — server should return 422 Unprocessable Entity."
          },
          "response": []
        },
        {
          "name": "422 Validation Error — Year Out of Range",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"make\": \"Ford\",\n  \"model\": \"F-150\",\n  \"year\": 1985,\n  \"mileage_km\": 320000,\n  \"engine_type\": \"Gasoline\",\n  \"service_frequency\": 3,\n  \"recall_count\": 2,\n  \"region\": \"Prairies\",\n  \"driving_style\": \"Mixed\"\n}",
              "options": {"raw": {"language": "json"}}
            },
            "url": {
              "raw": "{{base_url}}/predict",
              "host": ["{{base_url}}"],
              "path": ["predict"]
            },
            "description": "Year 1985 is below the allowed minimum (1990) — expect 422."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Prediction — GET (query params)",
      "item": [
        {
          "name": "High Risk — BMW 3 Series (2014, 245k km)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/predict?make=BMW&model=3+Series&year=2014&mileage_km=245000&engine_type=Gasoline&service_frequency=4&recall_count=4&region=Quebec&driving_style=City",
              "host": ["{{base_url}}"],
              "path": ["predict"],
              "query": [
                {"key": "make",               "value": "BMW"},
                {"key": "model",              "value": "3 Series"},
                {"key": "year",               "value": "2014"},
                {"key": "mileage_km",         "value": "245000"},
                {"key": "engine_type",        "value": "Gasoline"},
                {"key": "service_frequency",  "value": "4"},
                {"key": "recall_count",       "value": "4"},
                {"key": "region",             "value": "Quebec"},
                {"key": "driving_style",      "value": "City"}
              ]
            },
            "description": "Same high-risk BMW as the POST example, via query parameters."
          },
          "response": []
        },
